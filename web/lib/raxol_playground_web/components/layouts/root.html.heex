<!DOCTYPE html>
<html lang="en" class="[scrollbar-gutter:stable]">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <meta name="description" content="OTP-native terminal framework for Elixir. Same app in terminal, browser (LiveView), or SSH. AI agents, distributed swarm, time-travel debugging." />
    <meta property="og:title" content="Raxol -- OTP-native terminal framework for Elixir" />
    <meta property="og:description" content="Same app runs in a terminal, a browser via LiveView, or over SSH. Crash isolation, hot reload, AI agents, distributed swarm." />
    <meta property="og:image" content="https://raxol.io/images/social-preview.png" />
    <meta property="og:url" content="https://raxol.io" />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content="https://raxol.io/images/social-preview.png" />
    <.live_title suffix=" · Raxol">
      <%= assigns[:page_title] || "Raxol Playground" %>
    </.live_title>
    <link phx-track-static rel="stylesheet" href={~p"/assets/app.css"} />
    <script defer phx-track-static type="text/javascript" src={~p"/assets/app.js"}>
    </script>
  </head>
  <body class="antialiased">
    <%= @inner_content %>
  </body>
</html>
